webhook/__pycache__/
webhook/*.pyc
webhook/*.pyo
webhook/*.pyd
**/__pycache__/
**/*.pyc
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

